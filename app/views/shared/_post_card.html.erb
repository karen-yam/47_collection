<% if post.present? %>
  <!-- 投稿済 -->
  <%= link_to post_path(post), class: "block" do %>
    <div class="card bg-base-100 shadow-sm overflow-hidden transition-all duration-200 hover:shadow-md hover:-translate-y-1">
      <figure class="aspect-square overflow-hidden">
        <% if post.image.present? %>
          <%= image_tag(post.image.medium.url, class: "w-full h-full object-cover") %>
        <% else %>
          <div class="w-full h-full bg-gray-200 flex items-center justify-center">
            <span class="text-gray-400 text-2xl"></span>
          </div>
        <% end %>
      </figure>
      <div class="p-2 text-center">
        <p class="text-sm font-bold"><%= post.prefecture.name %></p>
      </div>
    </div>
  <% end %>
<% else %>
  <!-- 未投稿 -->
  <% if user_signed_in? && current_user == user %>
    <%= link_to new_post_path(prefecture_id: prefecture.id), class: "block" do %>
      <div class="card bg-base-100 shadow-sm overflow-hidden transition-all duration-200 hover:shadow-md hover:-translate-y-1">
        <div class="aspect-square bg-gray-100 flex items-center justify-center">
          <span class="text-gray-300 text-3xl"><i class="fa-solid fa-circle-plus" style="color: #317cb59c;"></i></span>
        </div>
        <div class="p-2 text-center">
          <p class="text-sm font-bold"><%= prefecture.name %></p>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card bg-base-100 shadow-sm overflow-hidden cursor-default">
      <div class="aspect-square flex items-center justify-center">
        <%= image_tag "coming_soon.png" %>
      </div>
      <div class="p-2 text-center">
        <p class="text-sm font-bold"><%= prefecture.name %></p>
      </div>
    </div>
  <% end %>
<% end %>
