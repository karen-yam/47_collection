<div class="bg-white block w-full p-6 border border-default rounded-lg shadow-xsoverflow-hidden transition-all duration-200 hover:shadow-md hover:-translate-y-1">
  <% if post.present? %>
      <div class="relative">
        <%= link_to post_path(post) do %>
          <%= image_tag(post.image.medium.url, class:"w-full aspect-square rounded object-cover") %>
        <% end %>
        <div class="absolute top-2 left-2 bg-green-600/80 text-white text-xs px-2 py-1 rounded">
          <%= post.prefecture.name %>
        </div>
      </div>
    
    <div class="card-body p-6">
      <div class="flex items-center justify-between">
        <h2 class="card-title text-lg">
          <%= link_to post.title, post_path(post) %>
        </h2>
        <% if user_signed_in? %>
          <% unless current_user.own?(post) %>
            <%= render "posts/like_buttons", { post: post } %>
          <% end %>
        <% end %>
      </div>
      <p class="text-gray-500 line-clamp-3"><%= post.body %></p>
      <div class="flex items-center gap-2 mt-2">
        <span class="font-semibold text-sm text-gray-800">
          <%= link_to post.user.name, user_posts_path(post.user), class: "hover:underline" %>
        </span>
        <span class="text-gray-400 text-xs"></span>
        <span class="text-gray-400 text-xs"><%= post.created_at.strftime("%Y/%m/%d") %></span>
      </div>
      <div class="pt-4">
        <% if post.category.present? %>
          <span class="inline-block bg-gray-200 rounded-full px-3 py-1 text-xs font-semibold text-gray-700 mr-2 mb-2">
            <%= link_to post.category.name, posts_path(category_id: post.category.id) %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>