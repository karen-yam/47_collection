<div class="flex items-center justify-center p-4">
  <div class="max-w-3xl w-full space-y-6">
    <h2 class="text-2xl font-bold text-gray-900 text-center">マイページ編集</h2>

    <div class="flex flex-col md:flex-row gap-6 items-stretch">
    <%# プロフィール設定  %>
    <div class="bg-white rounded-xl shadow-lg p-8 flex-1">
      <h3 class="text-lg font-semibold text-gray-800 mb-6 pb-2 border-b border-gray-200">プロフィール設定</h3>

      <% if @user&.errors&.any? %>
        <div class="bg-red-50 text-red-700 p-3 rounded-lg mb-4 text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: current_user, url: user_path(current_user), method: :patch, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">名前</label>
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">自己紹介</label>
            <%= f.text_area :bio, rows: 3, placeholder: "こんにちは！", class: "textarea textarea-bordered w-full rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
            <p class="text-xs text-gray-500 mt-1">最大100文字</p>
          </div>

          <fieldset class="fieldset bg-base-100 border-gray-300 rounded-box w-full border p-4">
            <legend class="fieldset-legend text-sm">投稿の公開設定</legend>
            <p class="text-xs text-gray-500 mb-4">公開設定をすると「みんなの投稿」に表示されます。</p>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <%= f.radio_button :is_published, "true", class: "radio-xs" %>
                <span>公開</span>
              </label>
              <label class="flex items-center gap-2">
                <%= f.radio_button :is_published, "false", class: "radio-xs" %>
                <span>非公開</span>
              </label>
            </div>
          </fieldset>

          <%= f.submit "プロフィールを更新する", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-lg transition-colors" %>
        </div>
      <% end %>
    </div>

    <%# ユーザー情報 %>
    <div class="bg-white rounded-xl shadow-lg p-8 flex-1">
      <h3 class="text-lg font-semibold text-gray-800 mb-6 pb-2 border-b border-gray-200">ユーザー情報</h3>

      <% if current_user.provider.present? %>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-700">メールアドレス</p>
              <p class="text-gray-900 mt-1"><%= current_user.email %></p>
            </div>
          </div>
          <p class="text-sm text-gray-500 bg-gray-50 rounded-lg p-3">Googleログインのため変更できません</p>
        </div>

      <% else %>
        <div class="space-y-4">
          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <div>
              <p class="text-sm font-medium text-gray-700">メールアドレス</p>
              <p class="text-gray-900 mt-1"><%= current_user.email %></p>
            </div>
            <%= link_to "編集", email_change_user_path(current_user), class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
          </div>

          <div class="flex items-center justify-between py-3 border-b border-gray-100">
            <div>
              <p class="text-sm font-medium text-gray-700">パスワード</p>
              <p class="text-gray-900 mt-1 tracking-widest">••••••••</p>
            </div>
            <%= link_to "編集", password_change_user_path(current_user), class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
    </div>

    <%= link_to "戻る", user_path(current_user), class: "block w-full btn btn-neutral btn-outline font-medium py-2.5 rounded-lg transition-colors text-center" %>
  </div>
</div>