<div class="flex items-center justify-center p-4">
  <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">メールアドレスの変更</h2>

    <% if @user&.errors&.any? %>
      <div class="bg-red-50 text-red-700 p-3 rounded-lg mb-4 text-sm">
        <ul class="list-disc list-inside space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: current_user, url: email_change_user_path(current_user), method: :patch, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">現在のメールアドレス</label>
          <p class="text-gray-500 text-sm px-4 py-2 bg-gray-50 rounded-lg"><%= current_user.email_in_database %></p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">新しいメールアドレス</label>
          <%= f.email_field :email, value: "", autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
        </div>

        <%= f.submit "変更する", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-lg transition-colors" %>
      </div>
    <% end %>

    <%= link_to "戻る", edit_user_path(current_user), class: "block w-full btn btn-neutral btn-outline font-medium py-2.5 rounded-lg transition-colors mt-3 text-center" %>
  </div>
</div>
