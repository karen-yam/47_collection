<div class="flex items-center justify-center p-4">
  <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">パスワードの変更</h2>

    <% if @user&.errors&.any? %>
      <div class="bg-red-50 text-red-700 p-3 rounded-lg mb-4 text-sm">
        <ul class="list-disc list-inside space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: current_user, url: password_change_user_path(current_user), method: :patch, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Ó
            新しいパスワード
            <% if @minimum_password_length %>
              <span class="text-xs text-gray-500">(<%= @minimum_password_length %>文字以上)</span>
            <% end %>
          </label>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">新しいパスワード（確認用）</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            現在のパスワード <span class="text-red-500">*</span>
          </label>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
        </div>

        <%= f.submit "パスワードを変更する", class: "w-full btn btn-lg btn-primary text-white font-medium py-2.5 rounded-lg transition-colors" %>
      </div>
    <% end %>

    <%= link_to "戻る", edit_user_path(current_user), class: "block w-full btn btn-lg btn-neutral btn-outline font-medium py-2.5 rounded-lg transition-colors mt-3 text-center" %>
  </div>
</div>
