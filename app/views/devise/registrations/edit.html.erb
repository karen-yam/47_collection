<div class="flex items-center justify-center p-4">
  <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">ユーザー編集</h2>
    <%= form_with model: @user, url: registration_path(resource_name), html: { method: :put }, local: true do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">名前</label>
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">自己紹介</label>
            <%= f.text_area :bio, rows: 3, placeholder: "こんにちは！", class: "textarea textarea-bordered w-full rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
            <p class="text-xs text-gray-500 mt-1">
              最大100文字
            </p>
          </div>
          <fieldset class="fieldset bg-base-100 border-gray-300 rounded-box w-full border p-4">
            <legend class="fieldset-legend text-sm">投稿の公開設定</legend>
            <p class="text-xs text-gray-500 mb-4">
              公開設定をすると「みんなの投稿」に表示されます。
            </p>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <%= f.radio_button :is_published, "true" , class: "radio-xs"%>
                <span>公開</span>
              </label>
              <label class="flex items-center gap-2">
                <%= f.radio_button :is_published, "false" , class: "radio-xs"%>
                <span>非公開</span>
              </label>
            </div>
          </fieldset>
          <%= f.submit "更新する", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-lg transition-colors mb-4" %>
          <%= link_to "戻る", user_path(@user), class: "block w-full btn btn-neutral btn-outline font-medium py-2.5 rounded-lg transition-colors mb-4" %>
        </div>
    <% end %>
  </div>
</div>
